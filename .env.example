# Copy this file to .env and adjust as needed.

# "ollama" (free, local, default) or "openai"
RAG_BACKEND=ollama

# Model name for whichever backend you chose
# ollama examples: llama3, mistral, phi3
# openai examples: gpt-4o-mini, gpt-4o
RAG_MODEL=llama3

# Only needed if RAG_BACKEND=openai
# OPENAI_API_KEY=your-key-here
